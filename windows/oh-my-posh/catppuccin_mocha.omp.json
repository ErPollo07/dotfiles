{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "os": "#ACB0BE",
    "closer": "p:os",
    "pink": "#F5C2E7",
    "lavender": "#B4BEFE",
    "blue": "#89B4FA"
  },

  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "plain",
          "foreground": "p:os",
          "template": "{{ .Icon }} "
        },
        {
          "type": "session",
          "style": "plain",
          "foreground": "p:blue",
          "template": "{{ .UserName }}@{{ .HostName }} "
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "p:pink",
          "properties": {
            "style": "full",          
            "home_icon": "~",
            "folder_icon": "\ue5fe"
          },
          "template": "{{ .Path }} "
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:lavender",
          "properties": {
            "fetch_status": false,
            "branch_icon": "\ue725 "
          },
          "template": "{{ .HEAD }} "
        },
        {
          "type": "text",
          "foreground": "p:closer",
          "style": "plain",
          "template": "\uf105"
        }
      ]
    },

    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:closer",
          "template": ""
        }
      ]
    }
  ],

  "final_space": true,
  "version": 3
}
